# Flask
FLASK_SECRET_KEY=replace-with-a-long-random-secret

# MongoDB Atlas or local MongoDB
# Example Atlas URI format:
# mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority&appName=<app-name>
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=dapv-auction
MONGO_DB_NAME=decentralized_auction
# Optional: seed used to encrypt auction-specific private keys at rest in Mongo
PRIVATE_KEY_CIPHER_SEED=change-this-seed
